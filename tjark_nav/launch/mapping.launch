<!--
  mapping.launch  –  RTAB-Map RGB-D SLAM + camera start/end detection
  ────────────────────────────────────────────────────────────────────────────
  Phase 1 of the mission: drive the robot around to build the map while the
  RGB-D camera automatically recognises the START (green panel) and END (red
  panel) signs and records their map-frame positions.

  Workflow
  ────────
    1.  roslaunch tjark_nav mapping.launch              # obstacle arena (default)
        roslaunch tjark_nav mapping.launch scene:=cafe  # cafe world

    2.  Drive the robot with teleop:
            rosrun teleop_twist_keyboard teleop_twist_keyboard.py

    3.  Point the camera at each coloured sign from within ~3 m:
          • GREEN panel beside the start  →  locks the START waypoint
          • RED   panel beside the end    →  locks the END   waypoint
        Each lock logs "✓ LOCKED …", drops a coloured marker in RViz
        (/detected_markers) and writes maps/<scene>_waypoints.yaml.

    4.  Save the occupancy map when coverage looks complete:
            # obstacle:
            rosrun map_server map_saver -f $(rospack find tjark_nav)/maps/map
            # cafe:
            rosrun map_server map_saver -f $(rospack find tjark_nav)/maps/cafe_map

    5.  Ctrl-C, then run Phase 2:
            roslaunch tjark_nav demo.launch [scene:=cafe]
        The AGV loads the map, AMCL localises, and it auto-navigates from the
        detected start to the detected end, avoiding both pedestrian crowds.

  Arguments
    scene  : "obstacle" (default) | "cafe"
    gui    : show Gazebo GUI (default true)
-->
<launch>
  <arg name="scene" default="obstacle"/>
  <arg name="gui"   default="true"/>

  <!-- ── scene-specific parameters ────────────────────────────────────────── -->
  <arg name="world_file" value="$(find tjark_nav)/worlds/obstacle_avoidance.world"
       if="$(eval arg('scene') == 'obstacle')"/>
  <arg name="x_spawn"    value="-10.0" if="$(eval arg('scene') == 'obstacle')"/>
  <arg name="y_spawn"    value="-5.0"  if="$(eval arg('scene') == 'obstacle')"/>
  <arg name="wp_file"    value="$(find tjark_nav)/maps/obstacle_waypoints.yaml"
       if="$(eval arg('scene') == 'obstacle')"/>

  <arg name="world_file" value="$(find tjark_nav)/worlds/cafe_world.world"
       unless="$(eval arg('scene') == 'obstacle')"/>
  <arg name="x_spawn"    value="0.0"   unless="$(eval arg('scene') == 'obstacle')"/>
  <arg name="y_spawn"    value="2.0"   unless="$(eval arg('scene') == 'obstacle')"/>
  <arg name="wp_file"    value="$(find tjark_nav)/maps/cafe_waypoints.yaml"
       unless="$(eval arg('scene') == 'obstacle')"/>

  <!-- ── Gazebo world + robot ─────────────────────────────────────────────── -->
  <include file="$(find tjark_nav)/launch/spawn_world.launch">
    <arg name="world_name" value="$(arg world_file)"/>
    <arg name="x_spawn"    value="$(arg x_spawn)"/>
    <arg name="y_spawn"    value="$(arg y_spawn)"/>
    <arg name="z_spawn"    value="0.30"/>
    <arg name="gui"        value="$(arg gui)"/>
  </include>

  <!-- ── RTAB-Map RGB-D SLAM ──────────────────────────────────────────────────
       Uses the depth camera (RGB + depth + camera_info) for SLAM/loop-closure
       and fuses the LiDAR /scan to build a clean 2-D occupancy grid for later
       AMCL + move_base navigation.  Wheel /odom supplies the motion prior. -->
  <!-- RTAB-Map 0.20+ split the nodes out of the rtabmap_ros metapackage;
       the SLAM node now lives in rtabmap_slam. -->
  <node pkg="rtabmap_slam" type="rtabmap" name="rtabmap"
        args="--delete_db_on_start" output="screen">
    <param name="frame_id"        value="base_link"/>
    <param name="odom_frame_id"   value="odom"/>
    <param name="map_frame_id"    value="map"/>

    <param name="subscribe_depth" value="true"/>
    <param name="subscribe_scan"  value="true"/>
    <param name="approx_sync"     value="true"/>
    <param name="queue_size"      value="30"/>

    <remap from="rgb/image"       to="/my_camera/color/image_raw"/>
    <remap from="depth/image"     to="/my_camera/depth/image_raw"/>
    <remap from="rgb/camera_info" to="/my_camera/color/camera_info"/>
    <remap from="scan"            to="/scan"/>
    <remap from="odom"            to="/odom"/>
    <!-- publish the 2-D occupancy grid on /map so RViz + map_saver see it -->
    <remap from="grid_map"        to="/map"/>

    <!-- 2-D SLAM: lock to the floor plane, build grid from the laser -->
    <param name="Reg/Force3DoF"            value="true"/>
    <param name="Optimizer/Slam2D"         value="true"/>
    <param name="Grid/FromDepth"           value="false"/>
    <param name="Grid/RangeMax"            value="12.0"/>
    <param name="Grid/CellSize"            value="0.05"/>
    <param name="RGBD/NeighborLinkRefining" value="true"/>
    <param name="RGBD/ProximityBySpace"     value="true"/>
    <param name="RGBD/AngularUpdate"        value="0.1"/>
    <param name="RGBD/LinearUpdate"         value="0.1"/>
  </node>

  <!-- ── Camera start/end marker detector ─────────────────────────────────── -->
  <node pkg="tjark_nav" type="marker_detector.py" name="marker_detector"
        output="screen">
    <param name="output_file" value="$(arg wp_file)"/>
    <param name="map_frame"   value="map"/>
  </node>

  <!-- ── RViz (mapping view: fixed frame = odom, always exists) ───────────── -->
  <node pkg="rviz" type="rviz" name="rviz"
        args="-d $(find tjark_nav)/rviz/mapping.rviz"
        required="false"/>
</launch>
